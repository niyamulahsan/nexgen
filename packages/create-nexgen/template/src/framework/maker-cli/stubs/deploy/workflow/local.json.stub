{
  "steps": [
    {
      "name": "Generate deploy files",
      "run": "deploy:create --server --force",
      "enabled": false
    },
    {
      "name": "Start shared infra",
      "run": "deploy:server",
      "enabled": true
    },
    {
      "name": "Start app stack",
      "run": "deploy:app",
      "enabled": true
    },
    {
      "name": "Import MySQL dump (optional)",
      "run": "deploy:db:import --file=deploy/nexgen.sql --database=nexgen",
      "enabled": false
    }
  ]
}
