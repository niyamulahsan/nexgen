[supervisord]
nodaemon=true
user=root
logfile=/dev/null
logfile_maxbytes=0
pidfile=/var/run/supervisord.pid
loglevel=info

[program:migrate]
command=/bin/sh -lc "/bin/sh /app/deploy/scripts/auto-migrate.sh {{RUNTIME_EXEC}}"
directory=/app
autostart=true
autorestart=false
priority=5
startsecs=0
startretries=1
exitcodes=0
stdout_logfile=/dev/stdout
stderr_logfile=/dev/stderr
stdout_logfile_maxbytes=0
stderr_logfile_maxbytes=0

[program:api]
command=/bin/sh -lc "{{RUNTIME_EXEC}} src/framework/maker-cli/src/index.mjs serve --prod --runtime={{RUNTIME_NAME}}"
directory=/app
autostart=true
autorestart=true
priority=20
startsecs=3
startretries=5
stopsignal=TERM
stopwaitsecs=20
redirect_stderr=true
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
stopasgroup=true
killasgroup=true

[program:scheduler]
command=/bin/sh -lc "{{RUNTIME_EXEC}} src/framework/maker-cli/src/index.mjs schedule:work --prod --runtime={{RUNTIME_NAME}}"
directory=/app
autostart=true
autorestart=true
priority=40
startsecs=3
startretries=5
stopsignal=TERM
stopwaitsecs=20
redirect_stderr=true
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
stopasgroup=true
killasgroup=true
